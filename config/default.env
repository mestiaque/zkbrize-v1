# ZKTeco Bridge Configuration
# Copy this to .env and edit

# Server
PORT=3000
HOST=0.0.0.0

# ERP API
LARAVEL_API_URL=http://your-laravel-app.com/api
LARAVEL_API_TOKEN=your-api-token-here

# ADMS Server (newer ZKTeco devices push to this)
ADMS_PORT=7788

# ZK TCP/IP (older devices - pull mode)
ZK_DEFAULT_PORT=4370
ZK_TIMEOUT=5000

# Sync Schedule (cron format)
SYNC_SCHEDULE=*/30 * * * *
ATTENDANCE_FETCH_SCHEDULE=*/15 * * * *

# Logs
LOG_LEVEL=info
